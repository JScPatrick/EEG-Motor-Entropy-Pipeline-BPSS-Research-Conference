# Entropy functions
# -----------------------------
def _sample_entropy_pure_python(x: np.ndarray, m: int, r: float) -> float:
    """
    Richman–Moorman sample entropy (Chebyshev distance), pure NumPy.
    ``r`` must be a finite positive tolerance (same scaling as antropy when matched for validation).
    """
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if x.size < (m + 2) or not np.isfinite(r) or r <= 0:
        return np.nan
    N = x.size

    def _phi(mm: int) -> float:
        xm = np.array([x[i : i + mm] for i in range(N - mm + 1)])
        dist = np.max(np.abs(xm[:, None, :] - xm[None, :, :]), axis=2)
        c_row = (dist <= r).sum(axis=0) - 1  # exclude self-match
        return float(c_row.sum())

    a = _phi(m + 1)
    b = _phi(m)
    if a <= 0 or b <= 0:
        return np.nan
    return float(-np.log(a / b))


def sample_entropy(
    x: np.ndarray,
    cfg: Config,
    m: Optional[int] = None,
    r: Optional[float] = None,
    r_frac: Optional[float] = None,
    *,
    force_custom: bool = False,
) -> float:
    """
    Sample Entropy (Richman–Moorman, Chebyshev distance).

    Uses ``cfg`` only (no module-global state): ``SAMPEN_USE_ANTROPY`` selects antropy when
    installed and ``force_custom`` is False; otherwise the pure-Python implementation.

    ``force_custom=True`` is for validation: compare Richman–Moorman vs antropy on identical (m, r).

    Embedding dimension ``m`` defaults to ``cfg.SAMPEN_M``. When ``r`` is None, ``r = r_frac * SD(x)``
    with ``r_frac`` from ``cfg.SAMPEN_R_FRAC`` unless overridden.
    """
    m_eff = int(cfg.SAMPEN_M if m is None else m)
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if x.size < (m_eff + 2):
        return np.nan

    if r is None:
        sd = np.std(x)
        if not np.isfinite(sd) or sd == 0:
            return np.nan
        frac = float(cfg.SAMPEN_R_FRAC if r_frac is None else r_frac)
        r_abs = frac * sd
    else:
        r_abs = float(r)
        if not np.isfinite(r_abs) or r_abs <= 0:
            return np.nan

    if (
        not force_custom
        and cfg.SAMPEN_USE_ANTROPY
        and _antropy_sample_entropy is not None
    ):
        try:
            return float(_antropy_sample_entropy(x, order=m_eff, r=r_abs))
        except Exception:
            pass

    return _sample_entropy_pure_python(x, m_eff, r_abs)

def _perm_delay_autocorr_first_minimum(x: np.ndarray, max_lag: int) -> int:
    """
    Standard delay for ordinal patterns: first local minimum of the normalized autocorrelation
    (lag >= 1). Falls back to 1 if none found or series too short.
    """
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if x.size < 20:
        return 1
    x = x - np.mean(x)
    max_lag = min(max_lag, x.size // 3, x.size - 2)
    max_lag = max(2, max_lag)
    acs: List[float] = []
    for lag in range(1, max_lag + 1):
        a, b = x[:-lag], x[lag:]
        den = float(np.linalg.norm(a) * np.linalg.norm(b))
        if den <= 0:
            acs.append(1.0)
        else:
            acs.append(float(np.dot(a, b) / den))
    acs_arr = np.asarray(acs, dtype=float)
    for i in range(1, len(acs_arr) - 1):
        if acs_arr[i] < acs_arr[i - 1] and acs_arr[i] <= acs_arr[i + 1]:
            return i + 1  # lag is 1-based index into ACF
    return 1


def _ordinal_pattern_bandt_pompe(w: np.ndarray) -> Tuple[int, ...]:
    """
    Ordinal pattern with lexicographic tie-breaking (Bandt & Pompe).
    Returns a tuple of length m giving the permutation that sorts the window ascending.
    """
    w = np.asarray(w, dtype=float)
    m = w.size
    # np.lexsort: sort by w (last key primary), then by index for ties
    return tuple(np.lexsort((np.arange(m, dtype=int), w)))


def permutation_entropy(x: np.ndarray, cfg: Config) -> float:
    """
    Bandt–Pompe permutation entropy (Physica A, 2002).

    - Embeddings: (x[i], x[i+tau], ..., x[i+(m-1)*tau]) with embedding dimension m = PERMEN_ORDER.
    - tau = PERMEN_DELAY if set, else first local minimum of normalized ACF (common practice).
    - Ties: lexicographic ordering (via numpy.lexsort on value then index).
    - Normalization: divide by log2(m!) if PERMEN_NORMALIZE.
    """
    order = cfg.PERMEN_ORDER
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    n = x.size

    if cfg.PERMEN_DELAY is not None:
        tau = max(1, int(cfg.PERMEN_DELAY))
    else:
        tau = _perm_delay_autocorr_first_minimum(x, cfg.PERMEN_DELAY_AUTO_MAX)

    # Need at least one full embedding window
    span = (order - 1) * tau
    if n < span + 1:
        return np.nan

    n_pat = n - span
    if n_pat < 1:
        return np.nan

    counts: Dict[Tuple[int, ...], int] = defaultdict(int)
    for i in range(n_pat):
        w = x[i : i + span + 1 : tau]
        if w.size != order:
            continue
        pat = _ordinal_pattern_bandt_pompe(w)
        counts[pat] += 1

    total = float(sum(counts.values()))
    if total <= 0:
        return np.nan

    pe = 0.0
    for c in counts.values():
        p = c / total
        pe -= p * math.log2(p)

    if cfg.PERMEN_NORMALIZE:
        max_pe = math.log2(math.factorial(order))
        if max_pe > 0:
            pe = pe / max_pe
    return float(pe)

def multiscale_entropy(
    x: np.ndarray,
    cfg: Config,
    scales: int = 5,
    m: Optional[int] = None,
) -> np.ndarray:
    """
    Coarse-grain by averaging non-overlapping windows of length s,
    then compute SampEn at each scale. Recomputes r at each scale (via sd) using ``cfg``.
    """
    m_eff = int(cfg.SAMPEN_M if m is None else m)
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if x.size < 50:
        return np.full(scales, np.nan)

    out: List[float] = []
    for s in range(1, scales + 1):
        n = x.size // s
        if n < 50:
            out.append(np.nan)
            continue
        y = np.mean(x[: n * s].reshape(n, s), axis=1)
        out.append(sample_entropy(y, cfg, m=m_eff, r=None, r_frac=cfg.SAMPEN_R_FRAC))
    return np.array(out, dtype=float)


def _resolve_entropy_n_jobs(cfg: Config) -> int:
    if cfg.ENTROPY_N_JOBS == 1:
        return 1
    if Parallel is None:
        return 1
    j = cfg.ENTROPY_N_JOBS
    if j == -1:
        return max(1, os.cpu_count() or 1)
    return max(1, int(j))


def _channel_entropy_block(ch: int, all_ep: np.ndarray, cfg: Config) -> Tuple[np.ndarray, float, float]:
    """One channel: MSE-by-scale row, SampEn, PermEn (used with optional joblib parallel)."""
    n_ep = all_ep.shape[0]
    if cfg.ENTROPY_PER_EPOCH:
        mse_rows = []
        samp_vals = []
        perm_vals: List[float] = []
        for e in range(n_ep):
            sig = all_ep[e, ch, :]
            if cfg.COMPUTE_MSE:
                mse_rows.append(
                    multiscale_entropy(sig, cfg, scales=cfg.MSE_SCALES, m=cfg.SAMPEN_M)
                )
            samp_vals.append(sample_entropy(sig, cfg, m=cfg.SAMPEN_M, r=None, r_frac=cfg.SAMPEN_R_FRAC))
            if cfg.COMPUTE_PERMEN:
                perm_vals.append(permutation_entropy(sig, cfg))
        if cfg.COMPUTE_MSE and mse_rows:
            mse_ch_row = np.nanmean(np.stack(mse_rows, axis=0), axis=0)
        else:
            mse_ch_row = np.full(cfg.MSE_SCALES, np.nan)
        samp_ch = float(np.nanmean(samp_vals))
        if cfg.COMPUTE_PERMEN:
            perm_ch = float(np.nanmean(perm_vals)) if perm_vals else np.nan
        else:
            perm_ch = np.nan
    else:
        sig = all_ep.mean(axis=0)[ch, :]
        samp_ch = sample_entropy(sig, cfg, m=cfg.SAMPEN_M, r=None, r_frac=cfg.SAMPEN_R_FRAC)
        if cfg.COMPUTE_MSE:
            mse_ch_row = multiscale_entropy(sig, cfg, scales=cfg.MSE_SCALES, m=cfg.SAMPEN_M)
        else:
            mse_ch_row = np.full(cfg.MSE_SCALES, np.nan)
        perm_ch = permutation_entropy(sig, cfg) if cfg.COMPUTE_PERMEN else np.nan
    return mse_ch_row, samp_ch, float(perm_ch)


def _sampen_per_ch_one(ch: int, all_ep: np.ndarray, cfg: Config) -> float:
    if cfg.ENTROPY_PER_EPOCH:
        vals = [
            sample_entropy(all_ep[e, ch, :], cfg, m=cfg.SAMPEN_M, r=None, r_frac=cfg.SAMPEN_R_FRAC)
            for e in range(all_ep.shape[0])
        ]
        return float(np.nanmean(vals))
    sig = all_ep.mean(axis=0)[ch, :]
    return float(sample_entropy(sig, cfg, m=cfg.SAMPEN_M, r=None, r_frac=cfg.SAMPEN_R_FRAC))


def sample_entropy_per_channel_from_epochs(
    epochs: List[np.ndarray],
    ch_names: List[str],
    cfg: Config,
) -> np.ndarray:
    """
    Per-channel SampEn (whole scalp). Uses ENTROPY_PER_EPOCH:
    True: mean of SampEn over epochs; False: SampEn on epoch-averaged signal.
    Returns shape (n_ch,) aligned with ch_names. NaN if no epochs or mismatch.
    """
    if not epochs or not ch_names:
        return np.array([], dtype=float)
    all_ep = np.stack(epochs, axis=0)  # (n_ep, n_ch, n_samp)
    n_ch_data, n_ch_names = all_ep.shape[1], len(ch_names)
    if n_ch_data != n_ch_names:
        print(
            f"[WARN] Channel count mismatch (data={n_ch_data}, names={n_ch_names}); "
            "skipping per-electrode SampEn for this subject."
        )
        return np.full(n_ch_names, np.nan, dtype=float)

    nj = _resolve_entropy_n_jobs(cfg)
    if Parallel is not None and delayed is not None and nj > 1 and n_ch_data > 1:
        parts = Parallel(n_jobs=nj)(
            delayed(_sampen_per_ch_one)(ch, all_ep, cfg) for ch in range(n_ch_data)
        )
        return np.asarray(parts, dtype=float)
    out = np.full(n_ch_data, np.nan, dtype=float)
    for ch in range(n_ch_data):
        out[ch] = _sampen_per_ch_one(ch, all_ep, cfg)
    return out


def _fft_rel_power_denom_hz(cfg: Config) -> Tuple[float, float]:
    if cfg.FFT_REL_POWER_DENOM_HZ is not None:
        return float(cfg.FFT_REL_POWER_DENOM_HZ[0]), float(cfg.FFT_REL_POWER_DENOM_HZ[1])
    return float(cfg.L_FREQ), float(cfg.H_FREQ)


def fft_bandpower_per_channel_from_epochs(
    epochs: List[np.ndarray],
    ch_names: List[str],
    sfreq: Optional[float],
    cfg: Config,
) -> Tuple[np.ndarray, np.ndarray]:
    """
    Band-limited power from **Welch** spectral density estimates.

    For each channel, a one-segment Welch PSD is computed **per epoch** (window = full epoch,
    Hann window), PSDs are averaged across epochs, then integrated over frequency for each
    band. This avoids phase-cancellation artifacts from averaging the time-domain signal before
    spectral analysis.

    Adjacent bands use half-open intervals ``[lo, hi)`` so shared edges (e.g. 4 Hz) are not
    double-counted; the **last** band uses ``[lo, hi]`` closed at ``hi``.

    Returns (absolute, relative) each shape (n_ch, n_bands). Absolute columns are
    :math:`\\int S(f)\\,df` in each band (``scaling='density'``: V²/Hz × Hz). Relative =
    band integral / integral of the same Welch PSD over the denominator band
    (``FFT_REL_POWER_DENOM_HZ`` or L_FREQ–H_FREQ).
    """
    n_b = len(cfg.FFT_BANDS)
    if not epochs or not ch_names or sfreq is None or sfreq <= 0:
        return np.array([]), np.array([])

    all_ep = np.stack(epochs, axis=0)
    n_ep, n_ch_data, n_samp = all_ep.shape
    n_ch_names = len(ch_names)
    if n_ch_data != n_ch_names:
        print(
            f"[WARN] Channel count mismatch (data={n_ch_data}, names={n_ch_names}); "
            "skipping per-electrode FFT band power for this subject."
        )
        nan2 = np.full((n_ch_names, n_b), np.nan, dtype=float)
        return nan2, nan2

    if n_samp < 8:
        nan2 = np.full((n_ch_data, n_b), np.nan, dtype=float)
        return nan2, nan2

    fs = float(sfreq)
    n_bands = len(cfg.FFT_BANDS)
    d_lo, d_hi = _fft_rel_power_denom_hz(cfg)

    out_abs = np.full((n_ch_data, n_b), np.nan, dtype=float)
    out_rel = np.full((n_ch_data, n_b), np.nan, dtype=float)

    for ch in range(n_ch_data):
        psd_stack: List[np.ndarray] = []
        freqs: Optional[np.ndarray] = None
        for e in range(n_ep):
            sig = all_ep[e, ch, :].astype(float)
            if not np.all(np.isfinite(sig)):
                sig = np.nan_to_num(sig, nan=0.0)
            sig = sig - np.mean(sig)
            freqs_w, pxx = sp_signal.welch(
                sig,
                fs=fs,
                nperseg=n_samp,
                noverlap=0,
                window="hann",
                scaling="density",
                detrend=False,
            )
            if freqs is None:
                freqs = freqs_w
            psd_stack.append(pxx)
        if not psd_stack or freqs is None:
            continue
        mean_psd = np.mean(np.stack(psd_stack, axis=0), axis=0)
        f = freqs

        denom_mask = (f >= d_lo) & (f <= d_hi)
        if np.count_nonzero(denom_mask) < 2:
            total_pow = np.nan
        else:
            total_pow = float(np.trapz(mean_psd[denom_mask], f[denom_mask]))
        use_rel = np.isfinite(total_pow) and total_pow > 0

        for b_idx, (_band_name, lo, hi) in enumerate(cfg.FFT_BANDS):
            if b_idx < n_bands - 1:
                mask = (f >= lo) & (f < hi)
            else:
                mask = (f >= lo) & (f <= hi)
            if np.count_nonzero(mask) < 2:
                continue
            band_pow = float(np.trapz(mean_psd[mask], f[mask]))
            out_abs[ch, b_idx] = band_pow
            if use_rel and np.isfinite(band_pow):
                out_rel[ch, b_idx] = band_pow / total_pow

    return out_abs, out_rel


def entropy_per_channel_from_epochs(
    epochs: List[np.ndarray],
    cfg: Config,
) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    """
    One pass over all EEG channels: MSE (per scale), SampEn, PermEn per channel.
    Returns (mse_ch (n_ch, n_scales), samp_ch (n_ch,), perm_ch (n_ch,)).
    Used for whole-scalp + ROI summaries and per-electrode CSV (reuse samp_ch; no second SampEn pass).
    """
    if epochs is None or len(epochs) == 0:
        return (
            np.zeros((0, cfg.MSE_SCALES)),
            np.array([], dtype=float),
            np.array([], dtype=float),
        )

    all_ep = np.stack(epochs, axis=0)
    n_ch = all_ep.shape[1]
    if n_ch == 0:
        return (
            np.zeros((0, cfg.MSE_SCALES)),
            np.array([], dtype=float),
            np.array([], dtype=float),
        )

    mse_ch = np.full((n_ch, cfg.MSE_SCALES), np.nan)
    samp_ch = np.full(n_ch, np.nan)
    perm_ch = np.full(n_ch, np.nan)

    nj = _resolve_entropy_n_jobs(cfg)
    if Parallel is not None and delayed is not None and nj > 1 and n_ch > 1:
        results = Parallel(n_jobs=nj)(
            delayed(_channel_entropy_block)(ch, all_ep, cfg) for ch in range(n_ch)
        )
        for ch, (mse_row, s, p) in enumerate(results):
            mse_ch[ch, :] = mse_row
            samp_ch[ch] = s
            perm_ch[ch] = p
    else:
        for ch in range(n_ch):
            mse_row, s, p = _channel_entropy_block(ch, all_ep, cfg)
            mse_ch[ch, :] = mse_row
            samp_ch[ch] = s
            perm_ch[ch] = p

    return mse_ch, samp_ch, perm_ch


def _mean_entropy_scalars(
    mse_ch: np.ndarray,
    samp_ch: np.ndarray,
    perm_ch: np.ndarray,
    roi_idx: Optional[List[int]],
    cfg: Config,
) -> Tuple[np.ndarray, float, float]:
    """Mean MSE/SampEn/PermEn across channels (all channels, or ROI subset by indices)."""
    if mse_ch.size == 0 or samp_ch.size == 0:
        return np.full(cfg.MSE_SCALES, np.nan), float("nan"), float("nan")
    if roi_idx is not None:
        if len(roi_idx) == 0:
            return np.full(cfg.MSE_SCALES, np.nan), float("nan"), float("nan")
        mse_ch = mse_ch[np.asarray(roi_idx, dtype=int)]
        samp_ch = samp_ch[np.asarray(roi_idx, dtype=int)]
        perm_ch = perm_ch[np.asarray(roi_idx, dtype=int)]
    mse_mean = np.nanmean(mse_ch, axis=0)
    samp_mean = float(np.nanmean(samp_ch))
    perm_mean = float(np.nanmean(perm_ch))
    return mse_mean, samp_mean, perm_mean


def _nan_entropy_roi_scalars(cfg: Config) -> Tuple[np.ndarray, float, float]:
    """Placeholder when COMPUTE_ROI is False."""
    return np.full(cfg.MSE_SCALES, np.nan), float("nan"), float("nan")


def entropy_from_epochs(
    epochs: List[np.ndarray],
    roi_idx: Optional[List[int]],
    cfg: Config,
) -> Tuple[np.ndarray, float, float]:
    """
    Backwards-compatible: one full-channel compute, then aggregate for whole scalp or ROI.
    Prefer calling entropy_per_channel_from_epochs once per condition in hot paths.
    """
    mse_ch, samp_ch, perm_ch = entropy_per_channel_from_epochs(epochs, cfg)
    return _mean_entropy_scalars(mse_ch, samp_ch, perm_ch, roi_idx, cfg)

# -----------------------------
# Stats helpers
# -----------------------------
def sem(x: np.ndarray, axis: int = 0) -> np.ndarray:
    x = np.asarray(x, dtype=float)
    n = np.sum(np.isfinite(x), axis=axis)
    sd = np.nanstd(x, axis=axis, ddof=1)
    return sd / np.sqrt(np.maximum(n, 1))

def paired_pvals_by_scale(a: np.ndarray, b: np.ndarray) -> np.ndarray:
    """
    a,b: (n_subj, n_scales)
    returns pvals (n_scales,)
    """
    pvals = np.full(a.shape[1], np.nan)
    for s in range(a.shape[1]):
        aa = a[:, s]
        bb = b[:, s]
        mask = np.isfinite(aa) & np.isfinite(bb)
        if mask.sum() >= 5:
            _, p = ttest_rel(aa[mask], bb[mask], nan_policy="omit")
            pvals[s] = p
    return pvals


def benjamini_hochberg_fdr(pvals: np.ndarray) -> np.ndarray:
    """
    Benjamini–Hochberg FDR-adjusted p-values (same length as input).
    Non-finite entries are left as NaN and excluded from the adjustment.
    """
    p = np.asarray(pvals, dtype=float)
    out = np.full_like(p, np.nan, dtype=float)
    mask = np.isfinite(p)
    if not np.any(mask):
        return out
    pv = p[mask]
    n = pv.size
    order = np.argsort(pv)
    ranked = pv[order]
    q = ranked * n / np.arange(1, n + 1)
    q = np.minimum.accumulate(q[::-1])[::-1]
    out_flat = np.empty(n)
    out_flat[order] = np.clip(q, 0.0, 1.0)
    out[mask] = out_flat
    return out


def antropy_sample_entropy_match_cfg(x: np.ndarray, cfg: Config) -> float:
    """antropy.sample_entropy with same m and r (absolute) as custom code."""
    if _antropy_sample_entropy is None:
        return np.nan
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if x.size < (cfg.SAMPEN_M + 2):
        return np.nan
    sd = np.std(x)
    if not np.isfinite(sd) or sd == 0:
        return np.nan
    r = cfg.SAMPEN_R_FRAC * sd
    try:
        return float(_antropy_sample_entropy(x, order=cfg.SAMPEN_M, r=r))
    except Exception:
        return np.nan


def collect_sampen_antropy_validation(
    subj: str,
    rest_epochs: List[np.ndarray],
    mi_epochs: List[np.ndarray],
    me_epochs: List[np.ndarray],
    ch_names: List[str],
    cfg: Config,
    rng: np.random.Generator,
) -> List[Dict[str, object]]:
    """
    Compare **pure Richman–Moorman** SampEn vs **antropy** on random epochs/channels (low overhead).

    The main pipeline may use antropy for speed when ``SAMPEN_USE_ANTROPY`` is True; this check
    always computes the pure-Python path (``force_custom``) for the first column so the CSV is
    a meaningful agreement probe, not antropy-vs-antropy.
    """
    rows: List[Dict[str, object]] = []
    if not cfg.SAMPEN_VALIDATION_ENABLE or _antropy_sample_entropy is None:
        return rows
    if cfg.SAMPEN_VALIDATION_EXHAUSTIVE:
        pick_subj = True
    else:
        pick_subj = rng.random() < cfg.SAMPEN_VALIDATION_SUBJECT_FRACTION
    if not pick_subj:
        return rows

    cond_map = [
        ("REST", rest_epochs),
        ("MI", mi_epochs),
        ("ME", me_epochs),
    ]
    for cond, ep_list in cond_map:
        if not ep_list or not ch_names:
            continue
        all_ep = np.stack(ep_list, axis=0)
        n_ep, n_ch, _ = all_ep.shape
        if n_ch != len(ch_names):
            continue
        n_ep_pick = min(cfg.SAMPEN_VALIDATION_MAX_EPOCHS_PER_COND, n_ep)
        n_ch_pick = min(cfg.SAMPEN_VALIDATION_N_CHANNELS, n_ch)
        ep_idx = rng.choice(n_ep, size=n_ep_pick, replace=False)
        ch_idx = rng.choice(n_ch, size=n_ch_pick, replace=False)
        for e in ep_idx:
            for ch in ch_idx:
                sig = all_ep[e, ch, :]
                c = sample_entropy(
                    sig,
                    cfg,
                    m=cfg.SAMPEN_M,
                    r=None,
                    r_frac=cfg.SAMPEN_R_FRAC,
                    force_custom=True,
                )
                a = antropy_sample_entropy_match_cfg(sig, cfg)
                ad = np.nan
                if np.isfinite(c) and np.isfinite(a):
                    ad = float(abs(c - a))
                rows.append({
                    "subject": subj,
                    "condition": cond,
                    "epoch_index": int(e),
                    "channel_index": int(ch),
                    "channel_name": ch_names[ch],
                    "sampen_pure_richman": c,
                    "sampen_antropy": a,
                    "abs_diff": ad,
                })
    return rows


def aggregate_sampen_by_electrode(
    per_subject: List[Tuple[str, List[str], np.ndarray, np.ndarray, np.ndarray]],
) -> pd.DataFrame:
    """
    per_subject: list of (subject_id, ch_names, samp_rest, samp_mi, samp_me)
    Each samp_* is (n_ch,) with NaNs when condition missing.
    Aggregates by normalized channel label; keeps a display name per key.
    """
    # norm_key -> {rest: [], mi: [], me: [], display: str}
    acc: Dict[str, Dict[str, object]] = defaultdict(
        lambda: {"rest": [], "mi": [], "me": [], "display": ""}
    )

    for _subj, names, sr, smi, sme in per_subject:
        if not names or sr.size == 0:
            continue
        n = min(len(names), sr.size, smi.size, sme.size)
        for i in range(n):
            key = _norm_ch_name(names[i])
            if not key:
                continue
            slot = acc[key]
            if not slot["display"]:
                slot["display"] = names[i]
            slot["rest"].append(float(sr[i]))
            slot["mi"].append(float(smi[i]))
            slot["me"].append(float(sme[i]))

    rows = []
    for key in sorted(acc.keys(), key=lambda k: acc[k]["display"] or k):
        slot = acc[key]
        disp = slot["display"] or key
        for cond, col_prefix in [("rest", "rest"), ("mi", "mi"), ("me", "me")]:
            vals = np.asarray(slot[cond], dtype=float)
            finite = vals[np.isfinite(vals)]
            n_sub = int(finite.size)
            rows.append({
                "channel_norm": key,
                "channel": disp,
                "condition": col_prefix.upper(),
                "n_subjects": n_sub,
                "sampen_mean": float(np.mean(finite)) if n_sub else np.nan,
                "sampen_sem": float(sem(finite)) if n_sub > 1 else (0.0 if n_sub == 1 else np.nan),
            })

    return pd.DataFrame(rows)


def aggregate_sampen_by_electrode_by_subject(
    per_subject: List[Tuple[str, List[str], np.ndarray, np.ndarray, np.ndarray]],
) -> pd.DataFrame:
    """
    One row per (subject, electrode): SampEn for REST / MI / ME at that channel.
    Used for custom ROI subsets (e.g. sensorimotor cortex only) in offline stats scripts.
    """
    rows: List[Dict[str, object]] = []
    for subj, names, sr, smi, sme in per_subject:
        if not names or sr.size == 0:
            continue
        n = min(len(names), sr.size, smi.size, sme.size)
        for i in range(n):
            key = _norm_ch_name(names[i])
            if not key:
                continue
            rows.append(
                {
                    "subject": subj,
                    "channel_norm": key,
                    "channel": names[i],
                    "sampen_rest": float(sr[i]),
                    "sampen_mi": float(smi[i]),
                    "sampen_me": float(sme[i]),
                }
            )
    return pd.DataFrame(rows)


def sampen_per_electrode_wide_csv(df_long: pd.DataFrame) -> pd.DataFrame:
    """One row per electrode; REST/MI/ME as mean, sem, n columns."""
    if df_long.empty:
        return df_long
    rows = []
    for key, g in df_long.groupby("channel_norm", sort=False):
        row: Dict[str, object] = {"channel_norm": key, "channel": g["channel"].iloc[0]}
        for _, r in g.iterrows():
            cond = str(r["condition"]).lower()
            row[f"sampen_{cond}_mean"] = r["sampen_mean"]
            row[f"sampen_{cond}_sem"] = r["sampen_sem"]
            row[f"n_subjects_{cond}"] = r["n_subjects"]
        rows.append(row)
    out = pd.DataFrame(rows)
    return out.sort_values("channel_norm")


def aggregate_fft_bandpower_by_electrode(
    per_subject: List[
        Tuple[str, List[str], List[str], np.ndarray, np.ndarray, np.ndarray, np.ndarray, np.ndarray, np.ndarray]
    ],
) -> pd.DataFrame:
    """
    per_subject: (subject_id, ch_names, band_names,
                  abs_rest, abs_mi, abs_me, rel_rest, rel_mi, rel_me)
    each *_mat shape: (n_ch, n_bands)
    """
    acc: Dict[Tuple[str, str], Dict[str, object]] = defaultdict(
        lambda: {
            "rest": [], "mi": [], "me": [],
            "rel_rest": [], "rel_mi": [], "rel_me": [],
            "display": "",
        }
    )

    for _subj, names, band_names, br, bmi, bme, rr, rmi, rme in per_subject:
        if not names or br.size == 0:
            continue
        n_ch = min(len(names), br.shape[0], bmi.shape[0], bme.shape[0], rr.shape[0], rmi.shape[0], rme.shape[0])
        n_bands = min(
            len(band_names),
            br.shape[1], bmi.shape[1], bme.shape[1],
            rr.shape[1], rmi.shape[1], rme.shape[1],
        )
        for i in range(n_ch):
            ch_key = _norm_ch_name(names[i])
            if not ch_key:
                continue
            for b in range(n_bands):
                band_name = str(band_names[b])
                key = (ch_key, band_name)
                slot = acc[key]
                if not slot["display"]:
                    slot["display"] = names[i]
                slot["rest"].append(float(br[i, b]))
                slot["mi"].append(float(bmi[i, b]))
                slot["me"].append(float(bme[i, b]))
                slot["rel_rest"].append(float(rr[i, b]))
                slot["rel_mi"].append(float(rmi[i, b]))
                slot["rel_me"].append(float(rme[i, b]))

    rows = []
    for (ch_key, band_name) in sorted(acc.keys(), key=lambda k: ((acc[k]["display"] or k[0]), k[1])):
        slot = acc[(ch_key, band_name)]
        disp = slot["display"] or ch_key
        for cond, rel_key in [("rest", "rel_rest"), ("mi", "rel_mi"), ("me", "rel_me")]:
            vals = np.asarray(slot[cond], dtype=float)
            finite = vals[np.isfinite(vals)]
            n_sub = int(finite.size)
            vals_r = np.asarray(slot[rel_key], dtype=float)
            finite_r = vals_r[np.isfinite(vals_r)]
            n_sub_r = int(finite_r.size)
            rows.append({
                "channel_norm": ch_key,
                "channel": disp,
                "band": band_name,
                "condition": cond.upper(),
                "n_subjects": n_sub,
                "bandpower_mean": float(np.mean(finite)) if n_sub else np.nan,
                "bandpower_sem": float(sem(finite)) if n_sub > 1 else (0.0 if n_sub == 1 else np.nan),
                "bandpower_rel_mean": float(np.mean(finite_r)) if n_sub_r else np.nan,
                "bandpower_rel_sem": float(sem(finite_r)) if n_sub_r > 1 else (0.0 if n_sub_r == 1 else np.nan),
            })

    return pd.DataFrame(rows)


def fft_bandpower_per_electrode_wide_csv(df_long: pd.DataFrame) -> pd.DataFrame:
    """
    One row per electrode per band, with REST/MI/ME mean/sem/n columns.
    """
    if df_long.empty:
        return df_long
    rows = []
    for (key, band), g in df_long.groupby(["channel_norm", "band"], sort=False):
        row: Dict[str, object] = {
            "channel_norm": key,
            "channel": g["channel"].iloc[0],
            "band": band,
        }
        for _, r in g.iterrows():
            cond = str(r["condition"]).lower()
            row[f"bandpower_{cond}_mean"] = r["bandpower_mean"]
            row[f"bandpower_{cond}_sem"] = r["bandpower_sem"]
            row[f"bandpower_rel_{cond}_mean"] = r["bandpower_rel_mean"]
            row[f"bandpower_rel_{cond}_sem"] = r["bandpower_rel_sem"]
            row[f"n_subjects_{cond}"] = r["n_subjects"]
        rows.append(row)
    out = pd.DataFrame(rows)
    return out.sort_values(["channel_norm", "band"])


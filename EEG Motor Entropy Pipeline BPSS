# Main pipeline
# -----------------------------
def run_pipeline(cfg: Config) -> Dict[str, object]:
    out_dir = os.path.join(cfg.DATASET_ROOT, cfg.OUT_DIR_NAME)
    os.makedirs(out_dir, exist_ok=True)

    subs = subject_ids(cfg)

    if not cfg.COMPUTE_ROI:
        print(
            "[INFO] COMPUTE_ROI=False: ROI summaries, ROI figures, ROI p-values, and ROI MSE CSVs omitted or NaN."
        )

    # Store per-subject results
    rows = []

    # We also store per-subject MSE curves (whole + ROI)
    mse_rest_whole, mse_mi_whole, mse_me_whole = [], [], []
    mse_rest_roi,   mse_mi_roi,   mse_me_roi   = [], [], []

    samp_rest_whole, samp_mi_whole, samp_me_whole = [], [], []
    samp_rest_roi,   samp_mi_roi,   samp_me_roi   = [], [], []

    perm_rest_whole, perm_mi_whole, perm_me_whole = [], [], []
    perm_rest_roi,   perm_mi_roi,   perm_me_roi   = [], [], []

    roi_idx_ref = None
    roi_found_ref = None
    roi_missing_ref = None

    sampen_validation_rows: List[Dict[str, object]] = []
    val_rng = np.random.default_rng(cfg.SAMPEN_VALIDATION_RNG_SEED)

    nj_ent = _resolve_entropy_n_jobs(cfg)
    if cfg.ENTROPY_N_JOBS != 1 and nj_ent == 1 and Parallel is None:
        print("[WARN] ENTROPY_N_JOBS>1 needs joblib (pip install joblib). Using one worker.")
    if cfg.SAMPEN_USE_ANTROPY and _antropy_sample_entropy is None:
        print(
            "[WARN] pip install antropy — SampEn uses a slow fallback; optional antropy validation CSV is off."
        )

    # (subject, ch_names, rest_vec, mi_vec, me_vec) for per-electrode CSV
    per_subject_sampen_by_ch: List[Tuple[str, List[str], np.ndarray, np.ndarray, np.ndarray]] = []
    # (subject, ch_names, band_names, abs_rest, abs_mi, abs_me, rel_rest, rel_mi, rel_me)
    per_subject_fft_bandpower_by_ch: List[
        Tuple[str, List[str], List[str], np.ndarray, np.ndarray, np.ndarray, np.ndarray, np.ndarray, np.ndarray]
    ] = []

    for subj in tqdm(subs, desc="Subjects"):
        rest_epochs, mi_epochs, me_epochs, subj_ch_names, subj_sfreq = load_subject_epochs(cfg, subj)

        # ROI indices from first subject that yields channel names (only if ROI analysis enabled)
        if cfg.COMPUTE_ROI and roi_idx_ref is None and subj_ch_names:
            roi_idx_ref, roi_found_ref, roi_missing_ref = pick_roi_indices(subj_ch_names, cfg.ROI_ELECTRODES)

        # If we never loaded any raw for this subject, skip
        if (len(rest_epochs) == 0) and (len(mi_epochs) == 0) and (len(me_epochs) == 0):
            continue
        if cfg.INCLUSION_ENABLE and not subject_passes_inclusion(rest_epochs, mi_epochs, me_epochs, cfg):
            continue

        sampen_validation_rows.extend(
            collect_sampen_antropy_validation(
                subj,
                rest_epochs,
                mi_epochs,
                me_epochs,
                subj_ch_names if subj_ch_names is not None else [],
                cfg,
                val_rng,
            )
        )

        # Per-channel MSE / SampEn / PermEn: one pass per condition (reuse SampEn for CSV + scalars)
        mse_r_ch, samp_r_ch, perm_r_ch = entropy_per_channel_from_epochs(rest_epochs, cfg)
        mse_mi_ch, samp_mi_ch, perm_mi_ch = entropy_per_channel_from_epochs(mi_epochs, cfg)
        mse_me_ch, samp_me_ch, perm_me_ch = entropy_per_channel_from_epochs(me_epochs, cfg)

        # Whole-scalp and ROI scalars (mean across channels; ROI = subset by index)
        mse_r_w, samp_r_w, perm_r_w = _mean_entropy_scalars(
            mse_r_ch, samp_r_ch, perm_r_ch, None, cfg
        )
        mse_mi_w, samp_mi_w, perm_mi_w = _mean_entropy_scalars(
            mse_mi_ch, samp_mi_ch, perm_mi_ch, None, cfg
        )
        mse_me_w, samp_me_w, perm_me_w = _mean_entropy_scalars(
            mse_me_ch, samp_me_ch, perm_me_ch, None, cfg
        )

        if cfg.COMPUTE_ROI:
            mse_r_roi, samp_r_roi, perm_r_roi = _mean_entropy_scalars(
                mse_r_ch, samp_r_ch, perm_r_ch, roi_idx_ref, cfg
            )
            mse_mi_roi_v, samp_mi_roi_v, perm_mi_roi_v = _mean_entropy_scalars(
                mse_mi_ch, samp_mi_ch, perm_mi_ch, roi_idx_ref, cfg
            )
            mse_me_roi_v, samp_me_roi_v, perm_me_roi_v = _mean_entropy_scalars(
                mse_me_ch, samp_me_ch, perm_me_ch, roi_idx_ref, cfg
            )
        else:
            _zr = _nan_entropy_roi_scalars(cfg)
            mse_r_roi, samp_r_roi, perm_r_roi = _zr
            mse_mi_roi_v, samp_mi_roi_v, perm_mi_roi_v = _zr
            mse_me_roi_v, samp_me_roi_v, perm_me_roi_v = _zr

        # Per-electrode SampEn: same vectors as entropy_per_channel_from_epochs (no duplicate SampEn)
        if subj_ch_names:
            n_ch = len(subj_ch_names)
            sr_ch = samp_r_ch if samp_r_ch.size == n_ch else np.full(n_ch, np.nan)
            smi_ch = samp_mi_ch if samp_mi_ch.size == n_ch else np.full(n_ch, np.nan)
            sme_ch = samp_me_ch if samp_me_ch.size == n_ch else np.full(n_ch, np.nan)
        else:
            sr_ch = smi_ch = sme_ch = np.array([])

        if subj_ch_names and sr_ch.size == len(subj_ch_names):
            per_subject_sampen_by_ch.append((subj, list(subj_ch_names), sr_ch, smi_ch, sme_ch))

        # Per-electrode FFT band power (whole scalp), condition-averaged signal
        if subj_ch_names and subj_sfreq is not None:
            n_ch = len(subj_ch_names)
            n_bands = len(cfg.FFT_BANDS)
            br_ch, rr_ch = fft_bandpower_per_channel_from_epochs(rest_epochs, subj_ch_names, subj_sfreq, cfg)
            bmi_ch, rmi_ch = fft_bandpower_per_channel_from_epochs(mi_epochs, subj_ch_names, subj_sfreq, cfg)
            bme_ch, rme_ch = fft_bandpower_per_channel_from_epochs(me_epochs, subj_ch_names, subj_sfreq, cfg)
            if br_ch.shape != (n_ch, n_bands):
                br_ch = np.full((n_ch, n_bands), np.nan)
            if rr_ch.shape != (n_ch, n_bands):
                rr_ch = np.full((n_ch, n_bands), np.nan)
            if bmi_ch.shape != (n_ch, n_bands):
                bmi_ch = np.full((n_ch, n_bands), np.nan)
            if rmi_ch.shape != (n_ch, n_bands):
                rmi_ch = np.full((n_ch, n_bands), np.nan)
            if bme_ch.shape != (n_ch, n_bands):
                bme_ch = np.full((n_ch, n_bands), np.nan)
            if rme_ch.shape != (n_ch, n_bands):
                rme_ch = np.full((n_ch, n_bands), np.nan)
            per_subject_fft_bandpower_by_ch.append(
                (
                    subj,
                    list(subj_ch_names),
                    [b[0] for b in cfg.FFT_BANDS],
                    br_ch,
                    bmi_ch,
                    bme_ch,
                    rr_ch,
                    rmi_ch,
                    rme_ch,
                )
            )

        # Save to group arrays
        mse_rest_whole.append(mse_r_w); mse_mi_whole.append(mse_mi_w); mse_me_whole.append(mse_me_w)
        mse_rest_roi.append(mse_r_roi); mse_mi_roi.append(mse_mi_roi_v); mse_me_roi.append(mse_me_roi_v)

        samp_rest_whole.append(samp_r_w); samp_mi_whole.append(samp_mi_w); samp_me_whole.append(samp_me_w)
        samp_rest_roi.append(samp_r_roi); samp_mi_roi.append(samp_mi_roi_v); samp_me_roi.append(samp_me_roi_v)

        perm_rest_whole.append(perm_r_w); perm_mi_whole.append(perm_mi_w); perm_me_whole.append(perm_me_w)
        perm_rest_roi.append(perm_r_roi); perm_mi_roi.append(perm_mi_roi_v); perm_me_roi.append(perm_me_roi_v)

        rows.append({
            "subject": subj,
            "n_rest_epochs": len(rest_epochs),
            "n_mi_epochs": len(mi_epochs),
            "n_me_epochs": len(me_epochs),
            "sampen_rest_whole": samp_r_w,
            "sampen_mi_whole": samp_mi_w,
            "sampen_me_whole": samp_me_w,
            "permen_rest_whole": perm_r_w,
            "permen_mi_whole": perm_mi_w,
            "permen_me_whole": perm_me_w,
            "sampen_rest_roi": samp_r_roi,
            "sampen_mi_roi": samp_mi_roi_v,
            "sampen_me_roi": samp_me_roi_v,
            "permen_rest_roi": perm_r_roi,
            "permen_mi_roi": perm_mi_roi_v,
            "permen_me_roi": perm_me_roi_v,
        })

    # Convert to arrays
    mse_rest_whole = np.asarray(mse_rest_whole, dtype=float)
    mse_mi_whole   = np.asarray(mse_mi_whole, dtype=float)
    mse_me_whole   = np.asarray(mse_me_whole, dtype=float)

    mse_rest_roi = np.asarray(mse_rest_roi, dtype=float)
    mse_mi_roi   = np.asarray(mse_mi_roi, dtype=float)
    mse_me_roi   = np.asarray(mse_me_roi, dtype=float)

    samp_rest_whole = np.asarray(samp_rest_whole, dtype=float)
    samp_mi_whole   = np.asarray(samp_mi_whole, dtype=float)
    samp_me_whole   = np.asarray(samp_me_whole, dtype=float)

    samp_rest_roi = np.asarray(samp_rest_roi, dtype=float)
    samp_mi_roi   = np.asarray(samp_mi_roi, dtype=float)
    samp_me_roi   = np.asarray(samp_me_roi, dtype=float)

    perm_rest_whole = np.asarray(perm_rest_whole, dtype=float)
    perm_mi_whole   = np.asarray(perm_mi_whole, dtype=float)
    perm_me_whole   = np.asarray(perm_me_whole, dtype=float)

    perm_rest_roi = np.asarray(perm_rest_roi, dtype=float)
    perm_mi_roi   = np.asarray(perm_mi_roi, dtype=float)
    perm_me_roi   = np.asarray(perm_me_roi, dtype=float)

    # Subject summary CSV
    df_subj = pd.DataFrame(rows)
    df_subj.to_csv(os.path.join(out_dir, "subject_summary.csv"), index=False)

    # Per-electrode SampEn: long + wide CSVs
    if cfg.SAVE_SAMPEN_PER_ELECTRODE_CSV and per_subject_sampen_by_ch:
        df_e_long = aggregate_sampen_by_electrode(per_subject_sampen_by_ch)
        df_e_long.to_csv(
            os.path.join(out_dir, "sampen_per_electrode_by_condition_long.csv"),
            index=False,
        )
        df_e_wide = sampen_per_electrode_wide_csv(df_e_long)
        df_e_wide.to_csv(os.path.join(out_dir, cfg.SAMPEN_PER_ELECTRODE_CSV_NAME), index=False)
        df_e_subj = aggregate_sampen_by_electrode_by_subject(per_subject_sampen_by_ch)
        df_e_subj.to_csv(
            os.path.join(out_dir, "sampen_per_electrode_by_subject_wide.csv"),
            index=False,
        )

    # Per-electrode FFT band power: long + wide CSVs
    if cfg.SAVE_FFT_BANDPOWER_PER_ELECTRODE_CSV and per_subject_fft_bandpower_by_ch:
        df_bp_long = aggregate_fft_bandpower_by_electrode(per_subject_fft_bandpower_by_ch)
        df_bp_long.to_csv(
            os.path.join(out_dir, "fft_bandpower_per_electrode_by_condition_long.csv"),
            index=False,
        )
        df_bp_wide = fft_bandpower_per_electrode_wide_csv(df_bp_long)
        df_bp_wide.to_csv(
            os.path.join(out_dir, cfg.FFT_BANDPOWER_PER_ELECTRODE_CSV_NAME),
            index=False,
        )

    # Save ROI matching report (only when ROI analysis ran)
    if cfg.COMPUTE_ROI:
        if roi_idx_ref is None:
            roi_idx_ref, roi_found_ref, roi_missing_ref = [], [], CFG.ROI_ELECTRODES

        roi_report = pd.DataFrame({
            "roi_requested": CFG.ROI_ELECTRODES,
            "found_in_data": [name in (roi_found_ref or []) for name in CFG.ROI_ELECTRODES]
        })
        roi_report.to_csv(os.path.join(out_dir, "roi_channel_match_report.csv"), index=False)

        print("\n=== ROI channel matching ===")
        print("Requested ROI:", CFG.ROI_ELECTRODES)
        print("Found ROI:", roi_found_ref)
        print("Missing ROI:", roi_missing_ref)
        print(f"ROI channels used: {len(roi_idx_ref)}")
    else:
        pd.DataFrame({"note": ["ROI analysis disabled (COMPUTE_ROI=False)"]}).to_csv(
            os.path.join(out_dir, "roi_channel_match_report.csv"), index=False
        )

    # -----------------------------
    # Save MSE curve-by-scale CSVs
    # -----------------------------
    scales = np.arange(1, cfg.MSE_SCALES + 1)
    def save_curve(name: str, arr: np.ndarray):
        df = pd.DataFrame({"scale": scales, "mean": np.nanmean(arr, axis=0), "sem": sem(arr, axis=0)})
        df.to_csv(os.path.join(out_dir, name), index=False)

    save_curve("mse_REST_curve_by_scale_whole.csv", mse_rest_whole)
    save_curve("mse_MI_curve_by_scale_whole.csv", mse_mi_whole)
    save_curve("mse_ME_curve_by_scale_whole.csv", mse_me_whole)

    if cfg.COMPUTE_ROI:
        save_curve("mse_REST_curve_by_scale_roi.csv", mse_rest_roi)
        save_curve("mse_MI_curve_by_scale_roi.csv", mse_mi_roi)
        save_curve("mse_ME_curve_by_scale_roi.csv", mse_me_roi)

    # -----------------------------
    # Paired p-values by scale (MI vs ME)
    # -----------------------------
    # Use subjects where both MI and ME are finite at a scale
    p_whole = paired_pvals_by_scale(mse_mi_whole, mse_me_whole)
    if cfg.COMPUTE_ROI:
        p_roi = paired_pvals_by_scale(mse_mi_roi, mse_me_roi)
    else:
        p_roi = np.full_like(p_whole, np.nan, dtype=float)
    if cfg.APPLY_FDR_TO_MI_VS_ME_PVALS:
        fdr_whole = benjamini_hochberg_fdr(p_whole)
        fdr_roi = benjamini_hochberg_fdr(p_roi) if cfg.COMPUTE_ROI else np.full_like(p_whole, np.nan)
    else:
        fdr_whole = np.full_like(p_whole, np.nan)
        fdr_roi = np.full_like(p_whole, np.nan)

    pd.DataFrame({
        "scale": scales,
        "p_MI_vs_ME_whole": p_whole,
        "p_MI_vs_ME_whole_fdr_bh": fdr_whole,
        "p_MI_vs_ME_roi": p_roi,
        "p_MI_vs_ME_roi_fdr_bh": fdr_roi,
    }).to_csv(os.path.join(out_dir, "pvals_MI_vs_ME_by_scale.csv"), index=False)
    if cfg.APPLY_FDR_TO_MI_VS_ME_PVALS:
        fam = "whole scalp scales" + ("; ROI scales" if cfg.COMPUTE_ROI else "")
        print(
            f"[INFO] MI vs ME p-values: Benjamini–Hochberg FDR ({fam}). "
            "See p_MI_vs_ME_*_fdr_bh columns."
        )

    if sampen_validation_rows:
        df_val = pd.DataFrame(sampen_validation_rows)
        df_val.to_csv(os.path.join(out_dir, "sampen_validation_antropy_vs_custom.csv"), index=False)
        ad = df_val["abs_diff"].to_numpy(dtype=float)
        ad = ad[np.isfinite(ad)]
        if ad.size:
            print(
                f"\n=== SampEn validation (antropy vs pure Richman–Moorman, n={ad.size}) ===\n"
                f"  mean |diff| = {float(np.mean(ad)):.6g}; max |diff| = {float(np.max(ad)):.6g}"
            )

    # -----------------------------
    # Figures (WHOLE + ROI)
    # -----------------------------
    if cfg.MAKE_FIGURES:
        # Figure 1: MSE curves (REST/MI/ME)
        fig1_mse_curves(
            out_dir,
            "Multiscale Entropy vs Scale (Whole scalp)",
            mse_rest_whole, mse_mi_whole, mse_me_whole,
            cfg, suffix="whole"
        )
        if cfg.COMPUTE_ROI:
            fig1_mse_curves(
                out_dir,
                "Multiscale Entropy vs Scale (Sensorimotor+context ROI)",
                mse_rest_roi, mse_mi_roi, mse_me_roi,
                cfg, suffix="roi"
            )

        # Figure 2: MI − ME paired dots
        fig2_mi_minus_me_dots(
            out_dir,
            "Paired MI − ME Differences by MSE Scale (Whole scalp)",
            mse_mi_whole, mse_me_whole,
            cfg, suffix="whole"
        )
        if cfg.COMPUTE_ROI:
            fig2_mi_minus_me_dots(
                out_dir,
                "Paired MI − ME Differences by MSE Scale (Sensorimotor+context ROI)",
                mse_mi_roi, mse_me_roi,
                cfg, suffix="roi"
            )

        # Figure 3: SampEn bars (REST/MI/ME)
        fig3_sampen_bars(
            out_dir,
            "Sample Entropy (single-scale) Across Conditions (Whole scalp)",
            samp_rest_whole, samp_mi_whole, samp_me_whole,
            cfg, suffix="whole"
        )
        if cfg.COMPUTE_ROI:
            fig3_sampen_bars(
                out_dir,
                "Sample Entropy (single-scale) Across Conditions (Sensorimotor+context ROI)",
                samp_rest_roi, samp_mi_roi, samp_me_roi,
                cfg, suffix="roi"
            )

    # PermEn summary CSV (only when PermEn was computed)
    if cfg.COMPUTE_PERMEN:
        perm_df = pd.DataFrame({
            "measure": ["PermEn_rest_whole", "PermEn_mi_whole", "PermEn_me_whole",
                        "PermEn_rest_roi", "PermEn_mi_roi", "PermEn_me_roi"],
            "mean": [np.nanmean(perm_rest_whole), np.nanmean(perm_mi_whole), np.nanmean(perm_me_whole),
                     np.nanmean(perm_rest_roi), np.nanmean(perm_mi_roi), np.nanmean(perm_me_roi)],
            "sem":  [sem(perm_rest_whole), sem(perm_mi_whole), sem(perm_me_whole),
                     sem(perm_rest_roi), sem(perm_mi_roi), sem(perm_me_roi)]
        })
        perm_df.to_csv(os.path.join(out_dir, "permen_summary_whole_and_roi.csv"), index=False)

    print(f"\nPipeline finished successfully.\nOutput directory: {out_dir}")
    return {
        "out_dir": out_dir,
        "roi_idx": roi_idx_ref,
        "roi_found": roi_found_ref,
        "roi_missing": roi_missing_ref,
    }


def export_sampen_per_electrode_by_subject_only(
    cfg: Config,
    out_path: Optional[str] = None,
) -> str:
    """
    Lightweight path: recompute **only** per-electrode Sample Entropy (REST / MI / ME) per
    subject and write ``sampen_per_electrode_by_subject_wide.csv``.

    Does **not** run MSE curves, FFT band power, figures, ``subject_summary.csv``, or other
    pipeline outputs — only the same ``entropy_per_channel_from_epochs`` SampEn vectors used
    in the full pipeline, then aggregates with ``aggregate_sampen_by_electrode_by_subject``.

    Use this when you already have group-level CSVs but need per-subject × electrode data
    for custom electrode subsets (e.g. sensorimotor cortex stats) without re-running the
    entire pipeline.

    Parameters
    ----------
    cfg
        Same ``Config`` as ``run_pipeline`` (``DATASET_ROOT``, subject range, inclusion, etc.).
    out_path
        Full path to the CSV. If ``None``, writes under ``DATASET_ROOT / OUT_DIR_NAME /
        sampen_per_electrode_by_subject_wide.csv``.

    Returns
    -------
    str
        Path written.
    """
    subs = subject_ids(cfg)
    per_subject_sampen_by_ch: List[Tuple[str, List[str], np.ndarray, np.ndarray, np.ndarray]] = []
    for subj in tqdm(subs, desc="Subjects (SampEn per-electrode export only)"):
        rest_epochs, mi_epochs, me_epochs, subj_ch_names, _subj_sfreq = load_subject_epochs(cfg, subj)
        if (len(rest_epochs) == 0) and (len(mi_epochs) == 0) and (len(me_epochs) == 0):
            continue
        if cfg.INCLUSION_ENABLE and not subject_passes_inclusion(rest_epochs, mi_epochs, me_epochs, cfg):
            continue

        _, samp_r_ch, _ = entropy_per_channel_from_epochs(rest_epochs, cfg)
        _, samp_mi_ch, _ = entropy_per_channel_from_epochs(mi_epochs, cfg)
        _, samp_me_ch, _ = entropy_per_channel_from_epochs(me_epochs, cfg)

        if subj_ch_names:
            n_ch = len(subj_ch_names)
            sr_ch = samp_r_ch if samp_r_ch.size == n_ch else np.full(n_ch, np.nan)
            smi_ch = samp_mi_ch if samp_mi_ch.size == n_ch else np.full(n_ch, np.nan)
            sme_ch = samp_me_ch if samp_me_ch.size == n_ch else np.full(n_ch, np.nan)
        else:
            sr_ch = smi_ch = sme_ch = np.array([])

        if subj_ch_names and sr_ch.size == len(subj_ch_names):
            per_subject_sampen_by_ch.append((subj, list(subj_ch_names), sr_ch, smi_ch, sme_ch))

    df = aggregate_sampen_by_electrode_by_subject(per_subject_sampen_by_ch)
    if out_path is None:
        out_dir = os.path.join(cfg.DATASET_ROOT, cfg.OUT_DIR_NAME)
        os.makedirs(out_dir, exist_ok=True)
        out_path = os.path.join(out_dir, "sampen_per_electrode_by_subject_wide.csv")
    else:
        out_path = os.path.abspath(out_path)
        d = os.path.dirname(out_path)
        if d:
            os.makedirs(d, exist_ok=True)
    df.to_csv(out_path, index=False)
    print(f"[export_sampen_per_electrode_by_subject_only] Wrote {len(df)} rows -> {out_path}")
    return out_path


def main() -> None:
    parser = argparse.ArgumentParser(
        description=(
            "EEGMMIDB entropy pipeline (REST/MI/ME). "
            "Configure via CLI args, environment (EEGMMIDB_ROOT), or CFG defaults."
        )
    )
    parser.add_argument(
        "--dataset-root",
        type=str,
        default=None,
        help=(
            "Path to local EEGMMIDB root. "
            "Overrides EEGMMIDB_ROOT env and CFG.DATASET_ROOT."
        ),
    )
    parser.add_argument(
        "--out-dir-name",
        type=str,
        default=None,
        help="Override output folder name under dataset root (default from CFG.OUT_DIR_NAME).",
    )
    args = parser.parse_args()

    # Priority: CLI --dataset-root > EEGMMIDB_ROOT env > CFG default in file
    root = (args.dataset_root or os.environ.get("EEGMMIDB_ROOT", "")).strip()
    if root:
        CFG.DATASET_ROOT = root
    if args.out_dir_name:
        CFG.OUT_DIR_NAME = str(args.out_dir_name).strip()

    # Safety guard for public template usage.
    if CFG.DATASET_ROOT.strip() in {"", "/path/to/EEGMMIDB"}:
        raise ValueError(
            "DATASET_ROOT is still a template path. "
            "Set --dataset-root, or export EEGMMIDB_ROOT, or edit CFG.DATASET_ROOT."
        )
    if not os.path.isdir(CFG.DATASET_ROOT):
        raise ValueError(
            f"DATASET_ROOT is not a directory: {CFG.DATASET_ROOT!r}\n"
            "Set Config.DATASET_ROOT to your EEGMMIDB folder, or set the EEGMMIDB_ROOT environment variable."
        )
    print(
        "[INFO] Run config: "
        f"dataset_root={CFG.DATASET_ROOT!r}, out_dir_name={CFG.OUT_DIR_NAME!r}, "
        f"subjects={CFG.SUBJECT_RANGE}, sample_n={CFG.SUBJECT_SAMPLE_N}, "
        f"sample_fraction={CFG.SUBJECT_SAMPLE_FRACTION}"
    )
    run_pipeline(CFG)

if __name__ == "__main__":
    main()


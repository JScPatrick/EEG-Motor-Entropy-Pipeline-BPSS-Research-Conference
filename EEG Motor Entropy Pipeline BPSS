@dataclass
class Config:
    # ---- dataset ----
    # Local folder containing subject subfolders (e.g. .../eegmmidb/S001/). No network access at runtime.
    DATASET_ROOT: str = "/path/to/EEGMMIDB"
    SUBJECT_PREFIX: str = "S"
    SUBJECT_RANGE: Tuple[int, int] = (1, 109)  # inclusive
    # After building the list from SUBJECT_RANGE, optionally take a random subset (without
    # replacement) for faster pilot runs.
    # - SUBJECT_SAMPLE_N: if set (e.g. 30), randomly select exactly that many subjects (overrides fraction).
    # - Else SUBJECT_SAMPLE_FRACTION: 1.0 = use everyone; e.g. 0.5 ≈ half the subjects.
    # Seed makes the same subset reproducible across runs (fair, not "first N subjects").
    SUBJECT_SAMPLE_N: Optional[int] = None
    SUBJECT_SAMPLE_FRACTION: float = 1.0
    SUBJECT_SAMPLE_SEED: int = 42
    # Inclusion (applied before random subsample). Scans SUBJECT_RANGE once (loads data; same as main loop).
    # For REST/MI/ME comparisons, require at least one epoch per condition (defaults below).
    INCLUSION_ENABLE: bool = True
    INCLUSION_REQUIRE_ALL_CONDITIONS: bool = True
    INCLUSION_MIN_EPOCHS_REST: int = 1
    INCLUSION_MIN_EPOCHS_MI: int = 1
    INCLUSION_MIN_EPOCHS_ME: int = 1
    EDF_RUN_PATTERN: str = "{subj}R{run:02d}.edf"

    # ---- conditions definition for EEGMMIDB ----
    # Rest: baseline eyes open run is R01 (per PhysioNet description)
    REST_RUNS: List[int] = None
    # Motor Execution (ME) and Motor Imagery (MI) for "left/right fist" tasks:
    # Task 1 (ME): runs 3, 7, 11
    # Task 2 (MI): runs 4, 8, 12
    ME_RUNS: List[int] = None
    MI_RUNS: List[int] = None

    # ---- preprocessing ----
    L_FREQ: float = 1.0
    H_FREQ: float = 40.0
    REF: str = "average"
    EPOCH_LEN_S: float = 10.0  # 10 s fixed epochs
    MSE_SCALES: int = 5

    # ---- entropy settings ----
    SAMPEN_M: int = 2
    SAMPEN_R_FRAC: float = 0.2  # r = 0.2 * SD (recomputed per coarse-grained series)
    PERMEN_ORDER: int = 3
    # Permutation entropy (Bandt & Pompe): embedding delay tau between samples in the pattern.
    # None = auto: first local minimum of normalized ACF (standard delay choice); int >= 1 = fixed tau.
    PERMEN_DELAY: Optional[int] = None
    PERMEN_DELAY_AUTO_MAX: int = 100  # max lag when searching ACF for auto tau
    PERMEN_NORMALIZE: bool = True  # divide by log2(order!) so H is in [0, 1]
    # If False: do not compute permutation entropy (faster; subject CSV columns stay NaN).
    COMPUTE_PERMEN: bool = True
    # If False: skip MSE computation (SampEn still computed as usual).
    COMPUTE_MSE: bool = True
    # True (default): SampEn, PermEn, MSE on each epoch, then mean over epochs (recommended).
    # False: average epochs to one trace per channel first, then entropy (legacy; faster).
    ENTROPY_PER_EPOCH: bool = True
    # Speed: same Richman–Moorman SampEn (m, r = r_frac·SD) via antropy when installed.
    SAMPEN_USE_ANTROPY: bool = True
    # Parallelize entropy across EEG channels (1 = off; -1 = all logical CPUs). Requires joblib.
    ENTROPY_N_JOBS: int = -1
    # name, low_hz, high_hz — integration uses half-open [lo, hi) between adjacent bands so
    # shared edges (e.g. 4 Hz) are not double-counted; the final band is closed at hi.
    FFT_BANDS: List[Tuple[str, float, float]] = None
    # Relative band power = band integral / integral over [lo, hi] on same PSD (default: L_FREQ, H_FREQ)
    FFT_REL_POWER_DENOM_HZ: Optional[Tuple[float, float]] = None

    # ---- ROI electrodes (YOUR LIST) ----
    ROI_ELECTRODES: List[str] = None
    # If False: skip ROI channel matching, ROI summary columns, ROI CSVs/figures, ROI p-values.
    # Whole-scalp / per-electrode outputs are unchanged. (ROI aggregation is cheap; savings are I/O + figures.)
    COMPUTE_ROI: bool = True

    # ---- outputs ----
    OUT_DIR_NAME: str = "entropy_results"
    MAKE_FIGURES: bool = True
    SAVE_CAPTIONS: bool = True
    # Wide CSV: one row per electrode, columns mean/sem/n for REST, MI, ME
    SAVE_SAMPEN_PER_ELECTRODE_CSV: bool = True
    SAMPEN_PER_ELECTRODE_CSV_NAME: str = "sampen_per_electrode_mean_across_subjects.csv"
    SAVE_FFT_BANDPOWER_PER_ELECTRODE_CSV: bool = True
    FFT_BANDPOWER_PER_ELECTRODE_CSV_NAME: str = "fft_bandpower_per_electrode_mean_across_subjects.csv"

    # ---- statistics: FDR on paired MI vs ME p-values by MSE scale ----
    # Benjamini–Hochberg within each family (whole scales together; ROI scales together).
    APPLY_FDR_TO_MI_VS_ME_PVALS: bool = True

    # ---- optional SampEn validation: antropy on a random subset (low runtime overhead) ----
    SAMPEN_VALIDATION_ENABLE: bool = True
    # Fraction of subjects (with usable epochs) selected for validation; ignored if EXHAUSTIVE.
    SAMPEN_VALIDATION_SUBJECT_FRACTION: float = 0.08
    SAMPEN_VALIDATION_RNG_SEED: int = 42
    SAMPEN_VALIDATION_MAX_EPOCHS_PER_COND: int = 2

def save_caption(out_dir: str, fname: str, text: str, cfg: Config):
    if not cfg.SAVE_CAPTIONS:
        return
    with open(os.path.join(out_dir, fname), "w", encoding="utf-8") as f:
        f.write(text.strip() + "\n")

def fig1_mse_curves(out_dir: str, title: str, rest: np.ndarray, mi: np.ndarray, me: np.ndarray,
                   cfg: Config, suffix: str):
    """
    rest/mi/me: (n_subj, n_scales)
    """
    scales = np.arange(1, cfg.MSE_SCALES + 1)
    rest_m, mi_m, me_m = np.nanmean(rest, axis=0), np.nanmean(mi, axis=0), np.nanmean(me, axis=0)
    rest_sem, mi_sem, me_sem = sem(rest, axis=0), sem(mi, axis=0), sem(me, axis=0)

    plt.figure(figsize=(8.2, 5.2))
    plt.plot(scales, rest_m, lw=2.8, color=cfg.COLOR_REST, label="REST")
    plt.fill_between(scales, rest_m - rest_sem, rest_m + rest_sem, color=cfg.COLOR_REST, alpha=0.15)

    plt.plot(scales, mi_m, lw=2.8, color=cfg.COLOR_MI, label="MI")
    plt.fill_between(scales, mi_m - mi_sem, mi_m + mi_sem, color=cfg.COLOR_MI, alpha=0.15)

    plt.plot(scales, me_m, lw=2.8, color=cfg.COLOR_ME, label="ME")
    plt.fill_between(scales, me_m - me_sem, me_m + me_sem, color=cfg.COLOR_ME, alpha=0.15)

    plt.title(title)
    plt.xlabel("MSE scale")
    plt.ylabel("Multiscale entropy (SampEn on coarse-grained signal)")
    plt.xticks(scales)
    plt.legend(frameon=False)
    plt.tight_layout()
    out_path = os.path.join(out_dir, f"Fig1_MSE_curves_{suffix}.png")
    plt.savefig(out_path, dpi=cfg.FIG_DPI)
    plt.close()

    within_subj = (
        "Within each subject, MSE is computed on each 10 s epoch and then averaged across epochs."
        if cfg.ENTROPY_PER_EPOCH
        else "Within each subject, epochs are averaged to one trace per channel before MSE."
    )
    cap = (
        f"Figure 1 ({suffix}): Multiscale entropy (MSE) across scales for REST (R01 eyes open), "
        f"motor imagery (MI; runs {cfg.MI_RUNS}), and motor execution (ME; runs {cfg.ME_RUNS}). "
        f"Lines show mean across subjects; shaded bands are ±SEM. "
        f"MSE computed via coarse-graining (scale 1–{cfg.MSE_SCALES}) followed by Sample Entropy. "
        f"{within_subj}"
    )
    save_caption(out_dir, f"Fig1_MSE_curves_{suffix}_caption.txt", cap, cfg)

def fig2_mi_minus_me_dots(out_dir: str, title: str, mi: np.ndarray, me: np.ndarray, cfg: Config, suffix: str):
    """
    MI-ME paired differences by scale.
    """
    scales = np.arange(1, cfg.MSE_SCALES + 1)
    diff = mi - me  # (n_subj, n_scales)
    plt.figure(figsize=(8.2, 5.2))

    # jittered dots per scale
    rng = np.random.default_rng(0)
    for i, s in enumerate(scales):
        y = diff[:, i]
        mask = np.isfinite(y)
        x = np.full(mask.sum(), s) + rng.normal(0, 0.06, size=mask.sum())
        plt.scatter(x, y[mask], s=18, color="black", alpha=0.25)

        # mean ± SEM overlay (black)
        m = np.nanmean(y)
        e = sem(y, axis=0)
        plt.errorbar([s], [m], yerr=[e], fmt="o", color="black", capsize=4, markersize=7)

    plt.axhline(0, ls="--", lw=1.6, color=cfg.COLOR_MI)
    plt.title(title)
    plt.xlabel("MSE scale")
    plt.ylabel("MI − ME (MSE)")
    plt.xticks(scales)
    plt.tight_layout()
    out_path = os.path.join(out_dir, f"Fig2_MI_minus_ME_dots_{suffix}.png")
    plt.savefig(out_path, dpi=cfg.FIG_DPI)
    plt.close()

    cap = (
        f"Figure 2 ({suffix}): Within-subject paired differences (MI − ME) in MSE by scale. "
        f"Each dot is one subject; black marker shows mean ± SEM. "
        f"Positive values indicate higher complexity during MI than ME."
    )
    save_caption(out_dir, f"Fig2_MI_minus_ME_dots_{suffix}_caption.txt", cap, cfg)

def fig3_sampen_bars(out_dir: str, title: str, rest: np.ndarray, mi: np.ndarray, me: np.ndarray,
                    cfg: Config, suffix: str):
    """
    SampEn bars for rest/mi/me.
    Inputs are vectors (n_subj,)
    """
    means = [np.nanmean(rest), np.nanmean(mi), np.nanmean(me)]
    errs = [sem(rest), sem(mi), sem(me)]
    labels = ["Rest", "MI", "ME"]
    colors = [cfg.COLOR_REST, cfg.COLOR_MI, cfg.COLOR_ME]

    plt.figure(figsize=(6.8, 5.2))
    plt.bar(labels, means, yerr=errs, capsize=6, color=colors, edgecolor="none")
    plt.title(title)
    plt.ylabel("Sample entropy")
    plt.tight_layout()
    out_path = os.path.join(out_dir, f"Fig3_SampEn_bars_{suffix}.png")
    plt.savefig(out_path, dpi=cfg.FIG_DPI)
    plt.close()

    samp_subj = (
        "Within each subject, SampEn is computed per epoch and averaged across epochs."
        if cfg.ENTROPY_PER_EPOCH
        else "Within each subject, epochs are averaged before SampEn."
    )
    cap = (
        f"Figure 3 ({suffix}): Single-scale Sample Entropy (SampEn) for REST, MI, and ME. "
        f"Bars show mean ± SEM across subjects. {samp_subj}"
    )
    save_caption(out_dir, f"Fig3_SampEn_bars_{suffix}_caption.txt", cap, cfg)


def subject_ids(cfg: Config) -> List[str]:
    a, b = cfg.SUBJECT_RANGE
    pool = [f"{cfg.SUBJECT_PREFIX}{i:03d}" for i in range(a, b + 1)]

    if cfg.INCLUSION_ENABLE:
        eligible: List[str] = []
        for subj in tqdm(pool, desc="Inclusion scan"):
            r, mi, me, _, _ = load_subject_epochs(cfg, subj)
            if subject_passes_inclusion(r, mi, me, cfg):
                eligible.append(subj)
        print(
            f"[INFO] Inclusion: {len(eligible)}/{len(pool)} subjects eligible "
            f"(require_all={cfg.INCLUSION_REQUIRE_ALL_CONDITIONS}; "
            f"min_epochs REST/MI/ME = "
            f"{cfg.INCLUSION_MIN_EPOCHS_REST}/{cfg.INCLUSION_MIN_EPOCHS_MI}/{cfg.INCLUSION_MIN_EPOCHS_ME})."
        )
        if len(eligible) == 0:
            raise RuntimeError(
                "No subjects meet inclusion criteria. Set INCLUSION_ENABLE=False to skip this gate, "
                "or lower INCLUSION_MIN_EPOCHS_* / set INCLUSION_REQUIRE_ALL_CONDITIONS=False."
            )
        ids = eligible
    else:
        ids = list(pool)

    rng = np.random.default_rng(int(cfg.SUBJECT_SAMPLE_SEED))

    n_fixed = cfg.SUBJECT_SAMPLE_N
    if n_fixed is not None:
        n_take = int(n_fixed)
        if n_take <= 0:
            raise ValueError("SUBJECT_SAMPLE_N must be a positive integer")
        if n_take > len(ids):
            raise RuntimeError(
                f"SUBJECT_SAMPLE_N={n_take} exceeds eligible subjects ({len(ids)}). "
                "Lower N, widen SUBJECT_RANGE, disable INCLUSION_ENABLE, or relax inclusion minima."
            )
        pick = rng.choice(len(ids), size=n_take, replace=False)
        pick.sort()
        out = [ids[i] for i in pick]
        print(
            f"[INFO] Random subject subsample: {len(out)}/{len(ids)} eligible subjects "
            f"(SUBJECT_SAMPLE_N={n_take}, seed={cfg.SUBJECT_SAMPLE_SEED})."
        )
        return out

    frac = float(cfg.SUBJECT_SAMPLE_FRACTION)
    if frac >= 1.0:
        return ids
    if not (0.0 < frac < 1.0):
        raise ValueError("SUBJECT_SAMPLE_FRACTION must be in (0, 1.0] or use 1.0 for all subjects")
    n_take = max(1, int(round(len(ids) * frac)))
    n_take = min(n_take, len(ids))
    pick = rng.choice(len(ids), size=n_take, replace=False)
    pick.sort()
    out = [ids[i] for i in pick]
    print(
        f"[INFO] Random subject subsample: {len(out)}/{len(ids)} subjects "
        f"(fraction={frac}, seed={cfg.SUBJECT_SAMPLE_SEED})."
    )
    return out

def subj_folder(cfg: Config, subj: str) -> str:
    return os.path.join(cfg.DATASET_ROOT, subj)

def run_path(cfg: Config, subj: str, run: int) -> str:
    return os.path.join(subj_folder(cfg, subj), cfg.EDF_RUN_PATTERN.format(subj=subj, run=run))

# -----------------------------
# Robust channel matching (ROI)
# -----------------------------
def _norm_ch_name(name: str) -> str:
    """
    Normalize channel names to make matching robust across EDF variations:
    - uppercase
    - strip whitespace
    - remove common punctuation
    """
    if name is None:
        return ""
    x = name.strip().upper()
    x = re.sub(r"[\s\.\-_/]", "", x)  # remove spaces and punctuation
    return x

def pick_roi_indices(ch_names: List[str], roi_names: List[str]) -> Tuple[List[int], List[str], List[str]]:
    """
    Returns:
      idx: channel indices found
      found: ROI names found (original forms)
      missing: ROI names missing
    """
    # Map normalized channel name -> index
    chan_map = {_norm_ch_name(ch): i for i, ch in enumerate(ch_names)}

    idx = []
    found = []
    missing = []

    for roi in roi_names:
        key = _norm_ch_name(roi)
        if key in chan_map:
            idx.append(chan_map[key])
            found.append(roi)
        else:
            missing.append(roi)

    # De-dup while preserving order
    seen = set()
    idx2, found2 = [], []
    for i, r in zip(idx, found):
        if i not in seen:
            seen.add(i)
            idx2.append(i)
            found2.append(r)

    return idx2, found2, missing

# -----------------------------
# Preprocessing / epoching
# -----------------------------
def load_and_preprocess_edf(path: str, cfg: Config) -> Optional[mne.io.BaseRaw]:
    if not os.path.exists(path):
        return None
    try:
        # Narrow scope: noisy EDF header parses emit RuntimeWarning; do not hide all NumPy/SciPy warnings globally.
        with warnings.catch_warnings():
            warnings.simplefilter("ignore", category=RuntimeWarning)
            raw = mne.io.read_raw_edf(path, preload=True, verbose=False)
        raw.pick_types(eeg=True)  # legacy warning is OK; can change to raw.pick('eeg') later
        raw.filter(cfg.L_FREQ, cfg.H_FREQ, verbose=False)
        raw.set_eeg_reference(cfg.REF, verbose=False)
        return raw
    except Exception as e:
        print(f"[WARN] Failed to read {path}: {e}")
        return None

def enforce_epoch_length(epoch_list: List[np.ndarray], expected_len: int) -> List[np.ndarray]:
    """
    Keep only epochs with exact sample length.
    Each epoch here is (n_ch, n_samp).
    """
    clean = []
    for ep in epoch_list:
        if ep is None:
            continue
        if ep.shape[-1] == expected_len:
            clean.append(ep)
    return clean

def epochs_from_annotations(raw: mne.io.BaseRaw, label: str, cfg: Config) -> List[np.ndarray]:
    """
    Extracts 10s epochs starting at the onset of each annotation == label.
    Returns list of (n_ch, n_samp) epochs.
    """
    sfreq = raw.info["sfreq"]
    n_samp = int(cfg.EPOCH_LEN_S * sfreq)

    # MNE stores onsets in seconds
    onsets_s = [float(a["onset"]) for a in raw.annotations if str(a["description"]) == label]
    epochs = []
    for onset in onsets_s:
        start = int(round(onset * sfreq))
        stop = start + n_samp
        if start < 0:
            continue
        if stop <= raw.n_times:
            seg = raw.get_data(start=start, stop=stop)  # (ch, samp)
            if seg.shape[1] == n_samp:
                epochs.append(seg)
    # Drop any accidental partials (extra safety)
    return enforce_epoch_length(epochs, n_samp)

def epochs_from_continuous(raw: mne.io.BaseRaw, cfg: Config) -> List[np.ndarray]:
    """
    For baseline runs that may not have T0/T1/T2 annotations:
    chunk into back-to-back 10s epochs from t=0.
    """
    sfreq = raw.info["sfreq"]
    n_samp = int(cfg.EPOCH_LEN_S * sfreq)
    n_epochs = raw.n_times // n_samp
    epochs = []
    for i in range(n_epochs):
        start = i * n_samp
        stop = start + n_samp
        seg = raw.get_data(start=start, stop=stop)
        if seg.shape[1] == n_samp:
            epochs.append(seg)
    return epochs


def load_subject_epochs(
    cfg: Config, subj: str
) -> Tuple[List[np.ndarray], List[np.ndarray], List[np.ndarray], Optional[List[str]], Optional[float]]:
    """
    Load REST / MI / ME epoch lists for one subject (same logic as main pipeline loop).
    Returns (rest_epochs, mi_epochs, me_epochs, ch_names, sfreq). Empty lists if folder missing or no runs load.
    """
    folder = subj_folder(cfg, subj)
    if not os.path.isdir(folder):
        return [], [], [], None, None

    subj_ch_names: Optional[List[str]] = None
    subj_sfreq: Optional[float] = None

    def _capture_ch_names(raw: mne.io.BaseRaw) -> None:
        nonlocal subj_ch_names, subj_sfreq
        if subj_ch_names is None:
            subj_ch_names = list(raw.ch_names)
        if subj_sfreq is None:
            subj_sfreq = float(raw.info["sfreq"])

    rest_epochs: List[np.ndarray] = []
    for run in cfg.REST_RUNS:
        p = run_path(cfg, subj, run)
        raw = load_and_preprocess_edf(p, cfg)
        if raw is None:
            continue
        _capture_ch_names(raw)
        rest_epochs.extend(epochs_from_continuous(raw, cfg))

    me_epochs: List[np.ndarray] = []
    for run in cfg.ME_RUNS:
        p = run_path(cfg, subj, run)
        raw = load_and_preprocess_edf(p, cfg)
        if raw is None:
            continue
        _capture_ch_names(raw)
        me_epochs.extend(epochs_from_annotations(raw, "T1", cfg))
        me_epochs.extend(epochs_from_annotations(raw, "T2", cfg))

    mi_epochs: List[np.ndarray] = []
    for run in cfg.MI_RUNS:
        p = run_path(cfg, subj, run)
        raw = load_and_preprocess_edf(p, cfg)
        if raw is None:
            continue
        _capture_ch_names(raw)
        mi_epochs.extend(epochs_from_annotations(raw, "T1", cfg))
        mi_epochs.extend(epochs_from_annotations(raw, "T2", cfg))

    return rest_epochs, mi_epochs, me_epochs, subj_ch_names, subj_sfreq


def subject_passes_inclusion(
    rest_epochs: List[np.ndarray],
    mi_epochs: List[np.ndarray],
    me_epochs: List[np.ndarray],
    cfg: Config,
) -> bool:
    """Standard-practice gate: enough usable epochs per condition for REST/MI/ME analyses."""
    if not cfg.INCLUSION_ENABLE:
        return True
    nr, nmi, nme = len(rest_epochs), len(mi_epochs), len(me_epochs)
    if cfg.INCLUSION_REQUIRE_ALL_CONDITIONS:
        return (
            nr >= cfg.INCLUSION_MIN_EPOCHS_REST
            and nmi >= cfg.INCLUSION_MIN_EPOCHS_MI
            and nme >= cfg.INCLUSION_MIN_EPOCHS_ME
        )
    # At least one condition meets its configured minimum (not merely non-empty).
    return (
        nr >= cfg.INCLUSION_MIN_EPOCHS_REST
        or nmi >= cfg.INCLUSION_MIN_EPOCHS_MI
        or nme >= cfg.INCLUSION_MIN_EPOCHS_ME
    )


